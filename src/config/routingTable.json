{
  "routes": {
    "reasoning_heavy": {
      "intent": "reasoning_heavy",
      "agent": "ReasoningAgent",
      "model": "phi4-reasoning-plus",
      "runtime": "lmstudio",
      "primary": true,
      "fallbacks": ["cloud_heavy_reasoning"]
    },
    "stats": {
      "intent": "stats",
      "agent": "StatsAgent",
      "model": "deepseek-r1-14b",
      "runtime": "lmstudio",
      "primary": true,
      "fallbacks": ["cloud_heavy_reasoning"]
    },
    "rag": {
      "intent": "rag",
      "agent": "RagAgent",
      "model": "phi-3-mini-128k",
      "runtime": "ollama",
      "primary": true,
      "fallbacks": ["qwen-2.5-14b-instruct", "cloud_rag"]
    },
    "coding": {
      "intent": "coding",
      "agent": "CodingAgent",
      "model": "deepseek-coder",
      "runtime": "ollama",
      "primary": true,
      "fallbacks": ["cloud_major_code"]
    },
    "math": {
      "intent": "math",
      "agent": "MathAgent",
      "model": "deepseek-math",
      "runtime": "ollama",
      "primary": true,
      "fallbacks": ["cloud_heavy_reasoning"]
    },
    "image_high": {
      "intent": "image_high",
      "agent": "ImageAgentHigh",
      "model": "llama-3.1-8b",
      "runtime": "ollama",
      "primary": true,
      "fallbacks": ["image_low", "cloud_creative"]
    },
    "image_low": {
      "intent": "image_low",
      "agent": "ImageAgentLow",
      "model": "dolphin-nemo-12b",
      "runtime": "ollama",
      "primary": true,
      "fallbacks": ["image_high"]
    },
    "stt": {
      "intent": "speech_to_text",
      "agent": "SpeechAgent",
      "model": "whisper-large",
      "runtime": "ollama",
      "primary": true,
      "fallbacks": ["cloud_stt"]
    },
    "tts": {
      "intent": "text_to_speech",
      "agent": "TTSAgent",
      "model": "xtts-v2",
      "runtime": "xtts",
      "primary": true,
      "fallbacks": ["cloud_tts"]
    },
    "vision": {
      "intent": "vision",
      "agent": "VisionAgent",
      "model": "phi-4-vision",
      "runtime": "lmstudio",
      "primary": true,
      "fallbacks": ["cloud_vision"]
    },
    "cloud": {
      "intent": "cloud",
      "agent": "CloudAgent",
      "model": "dynamic",
      "runtime": "cloud",
      "primary": false,
      "routes": {
        "heavy_reasoning": "claude-3-opus",
        "fallback_reasoning": "gpt-4.1",
        "vision": "gpt-4o",
        "design": "claude-3-sonnet",
        "cowork": "claude-3-opus",
        "major_code": "claude-3-opus",
        "creative": "claude-3-haiku",
        "mid_reasoning": "claude-3-sonnet",
        "stt": "whisper-1",
        "tts": "gpt-4o-mini-tts"
      }
    }
  },
  "fallback_chain": {
    "strategy": "cascading",
    "description": "On failure, try each fallback in order before escalating to cloud"
  }
}
