# =============================================================================
# APlus Orchestrator — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# =============================================================================

# ============================================================================= 
# TAILSCALE MESH HOST
# =============================================================================
# Your Tailscale mesh hostname (visible on https://login.tailscale.com/admin/machines)
# Example: your-device.tail5c19eb.ts.net
APLUS_TAILSCALE_HOST=https://your-tailscale-hostname.ts.net

# =============================================================================
# EXPRESS.JS ORCHESTRATOR
# =============================================================================
APLUS_ORCHESTRATOR_PORT=3200
APLUS_ORCHESTRATOR_HOST=localhost
NODE_ENV=development

# =============================================================================
# LOCAL SERVICE PORTS
# =============================================================================
# Port mappings for local services (adjust if running on different ports)
APLUS_OLLAMA_PORT=your-ollama-port
APLUS_LMSTUDIO_PORT=your-lmstudio-port
APLUS_XTTS_PORT=your-xtts-port
APLUS_ONNX_PORT=your-onnx-port
APLUS_CHROMADB_PORT=your-chromadb-port

# =============================================================================
# LOCAL SERVICE ENDPOINTS
# =============================================================================
# These are automatically constructed from APLUS_TAILSCALE_HOST + port
# But you can override them if needed

APLUS_OLLAMA_ENDPOINT=http://${APLUS_TAILSCALE_HOST}:${APLUS_OLLAMA_PORT}
APLUS_LMSTUDIO_ENDPOINT=http://${APLUS_TAILSCALE_HOST}:${APLUS_LMSTUDIO_PORT}/v1/chat/completions
APLUS_XTTS_ENDPOINT=http://${APLUS_TAILSCALE_HOST}:${APLUS_XTTS_PORT}
APLUS_ONNX_ENDPOINT=http://${APLUS_TAILSCALE_HOST}:${APLUS_ONNX_PORT}
APLUS_CHROMADB_ENDPOINT=http://${APLUS_TAILSCALE_HOST}:${APLUS_CHROMADB_PORT}
# Entry model for intent classification
APLUS_OLLAMA_ENTRY_MODEL=phi4-mini:latest

# Default pull timeout (ms)
APLUS_OLLAMA_PULL_TIMEOUT=300000

# =============================================================================
# LM STUDIO CONFIGURATION
# =============================================================================
# Health check interval (ms) — how often to check if LM Studio is online
APLUS_LMSTUDIO_HEALTH_CHECK_INTERVAL=30000

# Fallback when LM Studio unavailable (true = use Ollama, false = fail)
APLUS_LMSTUDIO_ALLOW_FALLBACK=true

# =============================================================================
# XTTS CONFIGURATION
# =============================================================================
# Directory holding your voice reference clips (<name>.wav) and their cached
# cloned-voice embeddings (<name>.json). Defaults to docker/config/voices.
# APLUS_XTTS_VOICES_PATH=./docker/config/voices

# =============================================================================
# AZURE (FOUNDRY) CREDENTIALS
# =============================================================================
# Get these from: https://portal.azure.com → AI Services → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# =============================================================================
# ANTHROPIC (CLAUDE) CREDENTIALS
# =============================================================================
# Get this from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# LOGGING & OBSERVABILITY
# =============================================================================
LOG_LEVEL=info
# Options: debug, info, warn, error

# Structured logging (true = JSON, false = human-readable)
APLUS_STRUCTURED_LOGGING=false

# =============================================================================
# RATE LIMITING
# =============================================================================
# Requests per minute per IP
APLUS_RATE_LIMIT_REQUESTS=60
APLUS_RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Allowed origins (comma-separated)
APLUS_CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# =============================================================================
# CONTAINER LIFECYCLE MANAGEMENT
# =============================================================================
# Path to docker-compose.yml directory
APLUS_COMPOSE_PATH=./docker

# Auto-start containers when a request needs them (true/false)
APLUS_CONTAINER_AUTO_START=true

# Auto-stop containers after idle timeout (true/false)
APLUS_CONTAINER_AUTO_STOP=true

# Idle timeout before stopping a container (ms) — default 10 minutes
APLUS_CONTAINER_IDLE_TIMEOUT_MS=600000

# Max time to wait for a container to become healthy (ms)
APLUS_CONTAINER_STARTUP_TIMEOUT_MS=120000

# How many health check attempts before giving up
APLUS_CONTAINER_HEALTH_RETRIES=10

# Delay between health check retries (ms)
APLUS_CONTAINER_HEALTH_INTERVAL_MS=3000

# GPU utilization % above which to fall back to cloud (0-100)
APLUS_GPU_SATURATION_THRESHOLD=90

# =============================================================================
# FUTURE: COST TRACKING (NOT YET IMPLEMENTED)
# =============================================================================
# APLUS_COST_TRACKING_ENABLED=false
# APLUS_COST_TRACKING_DATABASE_URL=postgresql://user:pass@localhost:5432/aplus_costs
